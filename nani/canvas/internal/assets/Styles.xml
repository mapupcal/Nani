<Styles>
    <Style class="NaniWindow" flex="row" direction="ltr">
    </Style>
    <Style class="Rectangle">
        <Dimension width="200" height="100" />
        <Colors opacity="1.0" background="#FFFFFFFF" border="#FF00FFFF" color="#00FFFFFF" />
        <BorderRadius radius="2"/>
        <Transform>
            <Translation x="20" y="10" />
            <Rotation a="" />
            <Scaling x="1.5" y ="1.5" />
            <Shearing x="1.5" y ="1.5" />
        </Transform>
    </Style>
    <Style class="Square">
        <Dimension width="100" height="100" />
        <BorderRadius tl="2" tr="2" bl="2" br="2"/>
        <Colors opacity="0.5" background="#FFFF00FF" border="#FF000FFF" color="#00FFFFFF" />
        <Shadow color="#808080FF" x="2" y="2" b="1.0" s="1.0" />
    </Style>
</Styles>